{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyMapper",
  "version": "0.1.0",
  "identifier": "com.keymapper.keymapper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "cargo build --release --manifest-path ../Cargo.toml -p daemon && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 720,
        "minHeight": 680,
        "width": 1200,
        "minWidth": 1100,
        "resizable": true,
        "title": "KeyMapper"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../../target/release/keymapper-daemon"]
  }
}
